Thumbs.db
desktop.ini

# 忽略编辑器文件
.vscode/
.idea/
*.swp
*.swo
*~

# 忽略日志文件
*.log
logs/

# 忽略临时文件
*.tmp
*.temp
*.cache

# 忽略备份文件
*.backup
*.bak
*.old
index.html.backup

# 忽略配置文件（包含敏感信息）
config/
*.env
*.config
.env.local
.env.*.local

# 忽略测试文件
*test*
*debug*
*.test.js
*.spec.js

# 忽略数据库文件
*.db
*.sqlite
*.sqlite3

# 忽略敏感文档
*_SECRET.md
*_CONFIG.md
*_PASSWORD.md
secrets/

# 忽略部署脚本中的临时文件
deploy_to_github.sh
